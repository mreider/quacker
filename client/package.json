{
  "name": "client",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:windows:x64": "electron-packager . user1-electron-app --platform=win32 --arch=x64 --out=out --overwrite",
    "build:windows:arm64": "electron-packager . user1-electron-app --platform=win32 --arch=arm64 --out=out --overwrite",
    "build:linux:x64": "electron-packager . user1-electron-app --platform=linux --arch=x64 --out=out --overwrite",
    "build:linux:arm64": "electron-packager . user1-electron-app --platform=linux --arch=arm64 --out=out --overwrite",
    "build:mac:x64": "electron-packager . user1-electron-app --platform=darwin --arch=x64 --out=out --overwrite",
    "build:mac:arm64": "electron-packager . user1-electron-app --platform=darwin --arch=arm64 --out=out --overwrite"
  },
  "dependencies": {
    "electron": "^25.0.0",
    "axios": "^0.27.2"
  },
  "devDependencies": {
    "electron-packager": "^17.1.1"
  }
}
